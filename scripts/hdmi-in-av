#!/usr/bin/env bash
# HDMI IN video + AUDIO uzivo. Zvuk = ALSA po imenu. Leaky queue protiv spam gresaka.
# Napomena: povremeni audio glitch = clock drift (fix = M3b drift tracking u drajveru).
set -euo pipefail
DEV=/dev/video5
ACARD="hw:CARD=rockchiphdmiin"
v4l2-ctl -d "$DEV" --set-dv-bt-timings query >/dev/null 2>&1 || true
exec gst-launch-1.0 \
  v4l2src device="$DEV" io-mode=dmabuf ! queue ! gtkwaylandsink sync=false \
  alsasrc device="$ACARD" buffer-time=80000 ! \
    queue max-size-time=0 max-size-bytes=0 max-size-buffers=0 leaky=downstream ! \
    audioconvert ! audioresample ! autoaudiosink sync=false
