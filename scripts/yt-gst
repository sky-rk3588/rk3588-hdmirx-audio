#!/usr/bin/env bash
# Živ YouTube: HW AV1 dekod (V4L2) + audio, bez reklama. Prozor sa borderom (gtkwaylandsink).
# Koristi:  yt-gst <youtube-url>
#   fullscreen: dupli klik na naslov prozora ili F11 (WM), ide na jedan monitor
#   niža rez: Q=1440 yt-gst <url>   (2160 default; 1080/1440/2160)
#   veći bafer: BUF=120 yt-gst <url>   (sekunde; default 80)
#   rotacija: ROT=vert yt-gst <url>    (identity default; vert|horiz|180)
set -e
URL="$1"; [ -z "$URL" ] && { echo "koristi: yt-gst <youtube-url>"; exit 1; }
ROT="${ROT:-identity}"; Q="${Q:-2160}"; BUF="${BUF:-80}"
NS=$(( BUF * 1000000000 ))
UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
YTDLP="$HOME/.local/bin/yt-dlp"
ARGS="--extractor-args youtube:player_client=android_vr,default"

mapfile -t U < <("$YTDLP" $ARGS -f "bv*[vcodec^=av01][height<=?$Q]+ba/bv*[height<=?$Q]+ba/b" -g "$URL" 2>/dev/null)
V="${U[0]}"; A="${U[1]}"
[ -z "$V" ] && { echo "yt-dlp nije dao stream (DRM/blokiran). Za takve: Chromium+uBO."; exit 1; }

VSINK="gtkwaylandsink rotate-method=$ROT qos=false"
QV="queue2 max-size-time=$NS max-size-bytes=0 max-size-buffers=0 use-buffering=true"
QA="queue2 max-size-time=$NS max-size-bytes=0 max-size-buffers=0 use-buffering=true"

export PAN_MESA_DEBUG=noafbc
export GST_PLUGIN_FEATURE_RANK=v4l2slav1dec:MAX,v4l2slh265dec:MAX,v4l2slh264dec:MAX

if [ -z "$A" ]; then
  exec gst-launch-1.0 -e uridecodebin uri="$V" name=d \
    d. ! queue ! $VSINK \
    d. ! queue ! audioconvert ! audioresample ! autoaudiosink
fi
exec gst-launch-1.0 -e \
  souphttpsrc location="$V" user-agent="$UA" ! $QV ! parsebin ! v4l2slav1dec ! queue max-size-buffers=16 ! $VSINK \
  souphttpsrc location="$A" user-agent="$UA" ! $QA ! decodebin ! audioconvert ! audioresample ! queue ! autoaudiosink
